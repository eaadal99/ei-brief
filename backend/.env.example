# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/ei_brief

# API key — frontend sends this in x-api-key header
API_KEY=eib_dev_key_2026

# Team password — shared gate for the team
TEAM_PASSWORD=

# AI provider
ANTHROPIC_API_KEY=

# Server
PORT=3001
NODE_ENV=development

# Frontend origin (for CORS in production)
ALLOWED_ORIGINS=

# External news APIs (optional but recommended)
# The Guardian — free key at https://open-platform.theguardian.com/access/
# If absent, Guardian fetcher is silently skipped. GDELT needs no key.
GUARDIAN_API_KEY=
